{
  "name": "king-agents",
  "displayName": "King Agents — 像素办公室 AI 编程团队",
  "description": "5个AI小人在像素办公室里帮你写代码！项目经理拆任务、程序员敲代码、质检员查Bug、运维搞部署、研究员翻资料，全程可视化。支持 DeepSeek/通义千问/智谱/豆包/Claude/GPT/Ollama本地，国内模型直接用。",
  "version": "0.2.2",
  "publisher": "king-agents",
  "_publisherNote": "IMPORTANT: publisher 值必须与 Marketplace 上创建的 Publisher ID 完全一致",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#3E2723",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/king-agents/king-agents"
  },
  "homepage": "https://github.com/king-agents/king-agents#readme",
  "bugs": {
    "url": "https://github.com/king-agents/king-agents/issues"
  },
  "preview": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "multi-agent",
    "coding-assistant",
    "code-generation",
    "ai-coding",
    "pixel-art",
    "pixel-office",
    "deepseek",
    "通义千问",
    "智谱",
    "豆包",
    "claude",
    "openai",
    "ollama",
    "ai-team",
    "copilot-alternative",
    "国产大模型"
  ],
  "activationEvents": [
    "onCommand:kingAgents.startSession",
    "onCommand:kingAgents.openBattlefield",
    "onView:kingAgents.minimap"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kingAgents.startSession",
        "title": "King Agents: Start New Task (新任务)",
        "icon": "$(play)"
      },
      {
        "command": "kingAgents.openBattlefield",
        "title": "King Agents: Open Office (打开办公室)",
        "icon": "$(symbol-event)"
      },
      {
        "command": "kingAgents.cancelSession",
        "title": "King Agents: Cancel Session (取消任务)",
        "icon": "$(debug-stop)"
      },
      {
        "command": "kingAgents.showStats",
        "title": "King Agents: Show Stats (统计)",
        "icon": "$(graph)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kingAgents",
          "title": "King Agents",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "kingAgents": [
        {
          "type": "webview",
          "id": "kingAgents.minimap",
          "name": "Minimap"
        }
      ]
    },
    "configuration": {
      "title": "King Agents",
      "properties": {
        "kingAgents.provider": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai",
            "deepseek",
            "doubao",
            "qwen",
            "zhipu",
            "openai-compatible",
            "ollama"
          ],
          "default": "deepseek",
          "description": "AI 模型提供商（国内推荐 DeepSeek 或通义千问，有免费额度）",
          "enumDescriptions": [
            "Anthropic Claude（海外，需要 API Key）",
            "OpenAI GPT（海外，需要 API Key）",
            "DeepSeek 深度求索（国内推荐，有免费额度）",
            "豆包 - 字节跳动（国内，有免费额度）",
            "通义千问 - 阿里云（国内推荐，有免费额度）",
            "智谱 AI（国内，有免费额度）",
            "OpenAI 兼容接口（自定义地址，支持任意兼容服务）",
            "Ollama 本地模型（完全免费，无需联网）"
          ]
        },
        "kingAgents.apiKey": {
          "type": "string",
          "default": "",
          "description": "API 密钥（去对应平台官网免费申请，Ollama 不需要填）"
        },
        "kingAgents.apiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "自定义 API 地址（仅「OpenAI兼容接口」和「Ollama」需要填，其他留空）"
        },
        "kingAgents.model": {
          "type": "string",
          "default": "",
          "description": "自定义模型名称（留空自动使用推荐模型）"
        },
        "kingAgents.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "(Deprecated: use kingAgents.apiKey instead) Anthropic API Key",
          "deprecationMessage": "This setting is deprecated. Please use kingAgents.apiKey instead."
        },
        "kingAgents.modelPreset": {
          "type": "string",
          "enum": [
            "balanced",
            "allstar",
            "economy"
          ],
          "default": "balanced",
          "description": "Model preset: balanced (strong+light), allstar (all strong), economy (all light)",
          "enumDescriptions": [
            "均衡：核心角色用强模型，辅助角色用轻量模型（推荐）",
            "全明星：全部角色用最强模型（效果最好，费用较高）",
            "经济：全部角色用轻量模型（最省钱）"
          ]
        },
        "kingAgents.maxRetries": {
          "type": "number",
          "default": 3,
          "description": "Max retries before escalating to user"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:all",
    "build": "node esbuild.config.mjs",
    "build:webview": "cd webview-ui && npm install && npx vite build",
    "build:all": "npm run build:webview && npm run build",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  }
}
